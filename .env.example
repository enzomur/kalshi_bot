# Kalshi API Credentials
# Get your API key from: https://kalshi.com/account/api

# Your Kalshi API Key ID
KALSHI_API_KEY_ID=your-api-key-id-here

# Path to your RSA private key file (PEM format)
# Generate with: openssl genrsa -out kalshi_private_key.pem 4096
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi_private_key.pem

# Environment: 'demo' or 'production'
# ALWAYS start with 'demo' for testing!
KALSHI_ENVIRONMENT=demo

# Optional: Override database path (default: data/kalshi_bot.db)
# DATABASE_PATH=/path/to/database.db

# Optional: Override settings file path (default: settings.yaml)
# SETTINGS_PATH=/path/to/settings.yaml

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
